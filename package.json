{
  "name": "mychampions-exercise-microservice",
  "version": "1.0.0",
  "description": "Production-ready YMove exercise translation proxy microservice for MyChampions",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "DOTENV_CONFIG_PATH=.env.local ts-node -r dotenv/config src/index.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/__tests__/unit'",
    "test:integration": "jest --testPathPattern='src/__tests__/integration'",
    "migrate:catalog:postgres": "node dist/infrastructure/postgres/migrate-redis-catalog-to-postgres.js",
    "migrate:catalog:postgres:dev": "ts-node src/infrastructure/postgres/migrate-redis-catalog-to-postgres.ts",
    "rebuild:catalog:redis": "node dist/infrastructure/postgres/rebuild-redis-catalog-from-postgres.js",
    "rebuild:catalog:redis:dev": "ts-node src/infrastructure/postgres/rebuild-redis-catalog-from-postgres.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.4.1",
    "pg": "^8.22.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "nock": "^13.5.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
