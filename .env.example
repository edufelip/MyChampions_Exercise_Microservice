# ─── MyChampions Exercise Microservice – Environment Variables ───────────────
# Copy this file to .env and fill in real values before running the service.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
# Number of reverse-proxy hops to trust for client IP extraction (Nginx=1)
# TRUST_PROXY_HOPS=1

# ── YMove API ─────────────────────────────────────────────────────────────────
# API key for YMove exercise API (https://ymove.app/exercise-api/docs)
YMOVE_API_KEY=

# ── Google Cloud Translation ─────────────────────────────────────────────────
# API key from Google Cloud Console (Cloud Translation API v2)
GOOGLE_TRANSLATE_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL (e.g. redis://localhost:6379 or rediss://user:pass@host:6380)
REDIS_URL=redis://localhost:6379

# ── Cache ─────────────────────────────────────────────────────────────────────
# TTL for cached exercise translations in seconds (default: 30 days)
# CACHE_TTL_SECONDS=2592000

# ── Upstream HTTP ─────────────────────────────────────────────────────────────
# Request timeout in milliseconds for upstream API calls
# UPSTREAM_TIMEOUT_MS=10000

# Request timeout in milliseconds for Google Translate API calls
# TRANSLATION_TIMEOUT_MS=10000

# Retries for retryable upstream failures (5xx/429/network)
# UPSTREAM_MAX_RETRIES=1

# Retries for retryable translation failures (5xx/429/network)
# TRANSLATION_MAX_RETRIES=1

# Max allowed forwarded URL length
# MAX_FORWARD_URL_LENGTH=2048

# Max allowed search query length
# MAX_SEARCH_LENGTH=200

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window size in milliseconds (default: 60 seconds)
# RATE_LIMIT_WINDOW_MS=60000
# Max requests per IP per window
# RATE_LIMIT_MAX=100
