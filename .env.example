# ─── MyChampions Exercise Microservice – Environment Variables ───────────────
# Copy this file to .env and fill in real values before running the service.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
# Number of reverse-proxy hops to trust for client IP extraction (Nginx=1)
# TRUST_PROXY_HOPS=1

# ── YMove API ─────────────────────────────────────────────────────────────────
# API key for YMove exercise API (https://ymove.app/exercise-api/docs)
YMOVE_API_KEY=

# ── Google Cloud Translation ─────────────────────────────────────────────────
# API key from Google Cloud Console (Cloud Translation API v2)
GOOGLE_TRANSLATE_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL (e.g. redis://localhost:6379 or rediss://user:pass@host:6380)
REDIS_URL=redis://localhost:6379

# ── Cache ─────────────────────────────────────────────────────────────────────
# TTL for cached exercise translations in seconds (default: 30 days)
# CACHE_TTL_SECONDS=2592000

# ── Upstream HTTP ─────────────────────────────────────────────────────────────
# Request timeout in milliseconds for upstream API calls
# UPSTREAM_TIMEOUT_MS=10000

# Request timeout in milliseconds for Google Translate API calls
# TRANSLATION_TIMEOUT_MS=10000

# Retries for retryable upstream failures (5xx/429/network)
# UPSTREAM_MAX_RETRIES=1

# Retries for retryable translation failures (5xx/429/network)
# TRANSLATION_MAX_RETRIES=1

# Max allowed forwarded URL length
# MAX_FORWARD_URL_LENGTH=2048

# Max allowed search query length
# MAX_SEARCH_LENGTH=200

# ── Catalog Search ────────────────────────────────────────────────────────────
# Enable/disable catalog endpoints
# CATALOG_ENABLED=true
# Background sync freshness window in ms (default: ~6 months)
# CATALOG_SYNC_INTERVAL_MS=15552000000
# Upstream page size used during full catalog sync
# CATALOG_SYNC_PAGE_SIZE=100
# Hard cap for number of pages during sync
# CATALOG_SYNC_MAX_PAGES=100
# Minimum query length before search matching is applied
# CATALOG_MIN_QUERY_LENGTH=1
# Levenshtein typo tolerance (0-2)
# CATALOG_TYPO_DISTANCE=1
# Shared key required by POST /catalog/review (disabled if omitted)
# CATALOG_REVIEW_API_KEY=
# How many catalog versions to retain in Redis after swaps
# CATALOG_VERSION_RETENTION=2
# Trigger catalog sync check at startup
# CATALOG_SYNC_ON_STARTUP=true
# Background sync check interval in milliseconds
# CATALOG_SYNC_BACKGROUND_INTERVAL_MS=900000
# Enable shadow validation (proxy vs catalog relevance)
# CATALOG_SHADOW_VALIDATION_ENABLED=false
# Sampling ratio for shadow validation checks [0..1]
# CATALOG_SHADOW_SAMPLE_RATE=0.1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window size in milliseconds (default: 60 seconds)
# RATE_LIMIT_WINDOW_MS=60000
# Max requests per IP per window
# RATE_LIMIT_MAX=100
